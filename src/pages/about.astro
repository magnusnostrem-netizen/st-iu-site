---
import about from '../content/site/about.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{about.title}</title>
    <style>
      body{margin:0;font-family:Inter,system-ui,-apple-system,"Segoe UI",sans-serif;background:linear-gradient(180deg,#08111f 0%,#0d1830 100%);color:#eef4ff}
      .wrap{width:min(900px,calc(100% - 32px));margin:0 auto;padding:32px 0 56px}
      .top{display:flex;justify-content:space-between;align-items:center;gap:20px;padding-bottom:18px}
      nav{display:flex;gap:18px;flex-wrap:wrap} nav a{text-decoration:none;color:#a7b4d6}
      .card{border:1px solid rgba(122,162,255,.16);border-radius:24px;background:rgba(15,24,48,.9);padding:28px}
      h1{margin:0 0 10px 0;font-size:clamp(2rem,4vw,3rem)} p{color:#c8d4f0;line-height:1.7}
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="top">
        <div>ST-IU</div>
        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/admin">Admin</a>
          <a href="/support">Support</a>
        </nav>
      </div>
      <div class="card">
        <h1>{about.title}</h1>
        <p>{about.intro}</p>
        <p>{about.body}</p>
      </div>
    </div>
  </body>
</html>
