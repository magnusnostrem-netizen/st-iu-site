---
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 10);
---

<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ST-IU</title>
    <meta name="description" content="ST-IU — daglige innlegg, prosjektlogg og research." />
    <style>
      :root {
        --bg: #0b1020;
        --panel: #121935;
        --soft: #1a2347;
        --text: #eef2ff;
        --muted: #9aa6d1;
        --line: #2a3568;
        --accent: #7aa2ff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, Segoe UI, Roboto, Arial, sans-serif;
        background: linear-gradient(180deg, #0a0f1f 0%, #0d1430 100%);
        color: var(--text);
        line-height: 1.6;
      }
      .wrap {
        max-width: 1040px;
        margin: 0 auto;
        padding: 28px;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 28px;
      }
      .brand {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }
      nav a {
        color: var(--muted);
        text-decoration: none;
        margin-left: 16px;
      }
      nav a:hover { color: var(--text); }
      .hero {
        background: radial-gradient(circle at top left, #1b2b63 0%, #121935 45%, #0f1730 100%);
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 36px;
        margin-bottom: 28px;
        box-shadow: 0 10px 35px rgba(0,0,0,.25);
      }
      .hero h1 {
        font-size: 2.4rem;
        line-height: 1.1;
        margin: 0 0 12px 0;
      }
      .hero p {
        margin: 0;
        max-width: 700px;
        color: var(--muted);
        font-size: 1.05rem;
      }
      .cta-row {
        margin-top: 22px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-block;
        padding: 11px 16px;
        border-radius: 12px;
        text-decoration: none;
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
      }
      .btn.primary {
        background: var(--accent);
        color: #081020;
        border-color: transparent;
        font-weight: 700;
      }
      .section-title {
        margin: 26px 0 10px 0;
        font-size: 1.1rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .08em;
      }
      .post-list {
        display: grid;
        gap: 14px;
      }
      .card {
        background: rgba(18, 25, 53, .9);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 18px;
      }
      .date {
        color: var(--muted);
        font-size: .92rem;
      }
      .card h2 {
        margin: 8px 0 0 0;
        font-size: 1.2rem;
      }
      .card h2 a {
        color: var(--text);
        text-decoration: none;
      }
      .card h2 a:hover {
        color: var(--accent);
      }
      footer {
        margin-top: 36px;
        padding-top: 20px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: .95rem;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <div class="brand">ST-IU</div>
        <nav>
          <a href="/">Hjem</a>
          <a href="/admin">Admin</a>
          <a href="https://github.com/magnusnostrem-netizen/st-iu-site">GitHub</a>
        </nav>
      </header>

      <section class="hero">
        <h1>Seid Tower Intelligence Unit</h1>
        <p>
          Daglige innlegg, prosjektlogg og research fra ST-IU. En enkel, rask og profesjonell side
          bygget for kontinuerlige oppdateringer.
        </p>
        <div class="cta-row">
          <a class="btn primary" href="/admin">Åpne admin</a>
          <a class="btn" href="https://github.com/magnusnostrem-netizen/st-iu-site">Se kildekode</a>
        </div>
      </section>

      <div class="section-title">Siste innlegg</div>

      <main class="post-list">
        {posts.length === 0 ? (
          <div class="card"><div class="date">Ingen innlegg enda.</div></div>
        ) : (
          posts.map((p) => (
            <article class="card">
              <div class="date">{new Date(p.data.date).toISOString().slice(0, 10)}</div>
              <h2><a href={"/posts/" + p.slug}>{p.data.title}</a></h2>
            </article>
          ))
        )}
      </main>

      <footer>
        ST-IU · st-iu.net
      </footer>
    </div>
  </body>
</html>
