---
import { getCollection } from 'astro:content';
import home from '../content/site/home.json';
import support from '../content/site/support.json';

const posts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 6);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>ST-IU</title>
    <meta name="description" content={home.intro} />
    <style>
      :root {
        --bg: #ffffff;
        --bg-soft: #f5f7fb;
        --panel: #ffffff;
        --panel-dark: #0d1117;
        --text: #0d1117;
        --muted: #5f6b85;
        --line: #d9e0ee;
        --accent: #7ea2ff;
        --accent-strong: #4f7dff;
        --shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(126,162,255,.18), transparent 26%),
          linear-gradient(180deg, #ffffff 0%, #f7f9fd 100%);
        color: var(--text);
        line-height: 1.6;
      }

      a { color: inherit; }

      .wrap {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(255,255,255,.82);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }

      .topbar-inner {
        min-height: 82px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand img {
        width: 54px;
        height: 54px;
        object-fit: contain;
        border-radius: 14px;
        background: #fff;
        padding: 5px;
        border: 1px solid var(--line);
      }

      .brand-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .brand-mark {
        font-size: .78rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--accent-strong);
        font-weight: 800;
      }

      .brand-name {
        font-size: 1rem;
        font-weight: 700;
      }

      nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        align-items: center;
      }

      nav a {
        text-decoration: none;
        color: var(--muted);
        font-weight: 500;
      }

      nav a:hover {
        color: var(--text);
      }

      .hero {
        padding: 42px 0 34px;
      }

      .hero-card {
        border-radius: 34px;
        overflow: hidden;
        border: 1px solid var(--line);
        background: linear-gradient(135deg, #0c1118 0%, #121926 45%, #eaf0ff 140%);
        box-shadow: var(--shadow);
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.15fr .85fr;
        gap: 0;
      }

      .hero-main {
        padding: 48px 42px;
        color: white;
      }

      .hero-side {
        background: linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(244,247,255,.98) 100%);
        color: var(--text);
        padding: 36px 30px;
        border-left: 1px solid rgba(255,255,255,.08);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: .83rem;
        text-transform: uppercase;
        letter-spacing: .14em;
        color: #a8c0ff;
        margin-bottom: 18px;
        font-weight: 800;
      }

      .hero-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 132px;
        height: 132px;
        border-radius: 28px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        margin-bottom: 22px;
      }

      .hero-logo img {
        width: 92px;
        height: 92px;
        object-fit: contain;
      }

      .hero h1 {
        margin: 0 0 16px 0;
        font-size: clamp(2.7rem, 6vw, 5.3rem);
        line-height: .94;
        letter-spacing: -.05em;
        max-width: 9ch;
      }

      .hero p {
        margin: 0;
        max-width: 58ch;
        color: rgba(255,255,255,.8);
        font-size: 1.07rem;
      }

      .cta-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 28px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        border: 1px solid transparent;
      }

      .btn.primary {
        background: white;
        color: #111827;
      }

      .btn.ghost {
        background: transparent;
        color: white;
        border-color: rgba(255,255,255,.18);
      }

      .hero-meta {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .meta-box {
        padding: 16px;
        border-radius: 18px;
        background: white;
        border: 1px solid var(--line);
      }

      .meta-label {
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .meta-value {
        font-size: 1.08rem;
        font-weight: 800;
      }

      .support-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-top: 24px;
      }

      .support-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: var(--panel);
        box-shadow: var(--shadow);
        padding: 24px;
      }

      .support-card h3 {
        margin: 0 0 10px 0;
        font-size: 1.2rem;
      }

      .support-card p {
        margin: 0 0 12px 0;
        color: var(--muted);
      }

      .big-line {
        font-size: 1.55rem;
        font-weight: 800;
        margin-bottom: 14px;
      }

      .vipps-btn {
        background: #ff5b24;
        color: white;
      }

      .paypal-btn {
        background: #0070ba;
        color: white;
      }

      .section {
        padding: 12px 0 56px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 20px;
        margin-bottom: 18px;
      }

      .section-head h2 {
        margin: 0 0 8px 0;
        font-size: 1.35rem;
      }

      .section-head p {
        margin: 0;
        color: var(--muted);
      }

      .posts {
        display: grid;
        gap: 16px;
      }

      .post-card {
        text-decoration: none;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: var(--panel);
        box-shadow: var(--shadow);
        padding: 22px;
      }

      .post-card:hover {
        border-color: #bfd0ff;
      }

      .post-date {
        color: var(--muted);
        font-size: .92rem;
      }

      .post-title {
        margin: 8px 0 8px 0;
        font-size: 1.2rem;
        line-height: 1.2;
      }

      .post-excerpt {
        margin: 0;
        color: var(--muted);
      }

      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
      }

      .info-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: var(--panel);
        box-shadow: var(--shadow);
        padding: 24px;
      }

      .info-card h3 {
        margin: 0 0 10px 0;
      }

      .info-card p {
        margin: 0;
        color: var(--muted);
      }

      footer {
        padding: 26px 0 42px;
        border-top: 1px solid rgba(0,0,0,.06);
        color: var(--muted);
        font-size: .95rem;
      }

      @media (max-width: 980px) {
        .hero-grid,
        .support-row,
        .grid-2 {
          grid-template-columns: 1fr;
        }

        .topbar-inner,
        .section-head {
          align-items: start;
          flex-direction: column;
        }

        .hero-main,
        .hero-side {
          padding: 30px 24px;
        }

        .hero h1 {
          max-width: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="topbar">
      <div class="wrap topbar-inner">
        <div class="brand">
          <img src="/logo.png" alt="ST-IU logo" onerror="this.src='/logo.svg'" />
          <div class="brand-text">
            <span class="brand-mark">ST-IU</span>
            <span class="brand-name">Seid Tower Intelligence Unit</span>
          </div>
        </div>

        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/admin">Admin</a>
          <a href="/support">Support</a>
        </nav>
      </div>
    </div>

    <main class="wrap">
      <section class="hero">
        <div class="hero-card">
          <div class="hero-grid">
            <div class="hero-main">
              <div class="eyebrow">{home.eyebrow}</div>

              <div class="hero-logo">
                <img src="/logo.png" alt="ST-IU logo" onerror="this.src='/logo.svg'" />
              </div>

              <h1>{home.title}</h1>
              <p>{home.intro}</p>

              <div class="cta-row">
                <a class="btn primary" href="/admin">Open admin</a>
                <a class="btn ghost" href="#latest">Latest posts</a>
              </div>
            </div>

            <div class="hero-side">
              <div class="hero-meta">
                <div class="meta-box">
                  <div class="meta-label">{home.publishingLabel}</div>
                  <div class="meta-value">{home.publishingValue}</div>
                </div>
                <div class="meta-box">
                  <div class="meta-label">{home.platformLabel}</div>
                  <div class="meta-value">{home.platformValue}</div>
                </div>
                <div class="meta-box">
                  <div class="meta-label">{home.statusLabel}</div>
                  <div class="meta-value">{home.statusValue}</div>
                </div>
                <div class="meta-box">
                  <div class="meta-label">{home.simpleTitle}</div>
                  <div class="meta-value" style="font-size:1rem">{home.simpleText}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="support-row">
          <div class="support-card">
            <h3>Vipps</h3>
            <p>{support.vippsText}</p>
            <div class="big-line">{support.vippsNumber}</div>
            <a class="btn vipps-btn" href="https://vipps.no/" target="_blank" rel="noreferrer">Open Vipps</a>
          </div>

          <div class="support-card">
            <h3>PayPal</h3>
            <p>{support.paypalText}</p>
            <div class="big-line">paypal.me/punktump</div>
            <a class="btn paypal-btn" href={support.paypalUrl} target="_blank" rel="noreferrer">Donate with PayPal</a>
          </div>
        </div>
      </section>

      <section class="section" id="latest">
        <div class="section-head">
          <div>
            <h2>{home.latestTitle}</h2>
            <p>{home.latestText}</p>
          </div>
        </div>

        <div class="posts">
          {posts.length === 0 ? (
            <div class="post-card">
              <div class="post-date">No posts yet</div>
              <h3 class="post-title">The first post will appear soon</h3>
            </div>
          ) : (
            posts.map((p) => (
              <a class="post-card" href={"/posts/" + p.slug}>
                <div class="post-date">{new Date(p.data.date).toISOString().slice(0, 10)}</div>
                <h3 class="post-title">{p.data.title}</h3>
                <p class="post-excerpt">Open the post to read more.</p>
              </a>
            ))
          )}
        </div>
      </section>

      <section class="section">
        <div class="grid-2">
          <div class="info-card">
            <h3>{home.sideTitle}</h3>
            <p>{home.sideText}</p>
          </div>
          <div class="info-card">
            <h3>{home.nextTitle}</h3>
            <p>{home.nextText}</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="wrap">ST-IU · Seid Tower Intelligence Unit</footer>
  </body>
</html>
